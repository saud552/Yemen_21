# ============================================
# إعدادات البوت الأساسية
# ============================================
BOT_TOKEN=your_bot_token_here
BOT_NAME=ZphisherProBot
WEBHOOK_URL=
WEBHOOK_SECRET=

# ============================================
# إعدادات الإدارة
# ============================================
ADMIN_IDS=123456789,987654321
SUPER_ADMIN_IDS=123456789
AUTHORIZED_CHANNELS=
MAX_USERS=1000
REQUIRE_APPROVAL=true

# ============================================
# إعدادات قاعدة البيانات
# ============================================
DATABASE_URL=sqlite:///./bot_database.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# إعدادات الأمان
# ============================================
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
ENCRYPTION_KEY=your_fernet_encryption_key_here
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=1800

# ============================================
# إعدادات Zphisher
# ============================================
ZPHISHER_PATH=/path/to/zphisher
ZPHISHER_SERVER_PATH=/path/to/zphisher/www
ZPHISHER_DATA_PATH=/path/to/zphisher/captured
CLOUDFLARED_PATH=/path/to/cloudflared
LOCALXPOSE_PATH=/path/to/loclx
DEFAULT_TUNNEL=cloudflared
DEFAULT_PORT=8080

# ============================================
# إعدادات السجلات
# ============================================
LOG_LEVEL=INFO
LOG_FILE=bot.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# ============================================
# إعدادات الملفات والتخزين
# ============================================
UPLOAD_PATH=./uploads
BACKUP_PATH=./backups
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=.txt,.json,.csv,.xlsx,.pdf
CLEANUP_INTERVAL=86400

# ============================================
# إعدادات معدل الطلبات
# ============================================
RATE_LIMIT_MESSAGES=30
RATE_LIMIT_WINDOW=60
RATE_LIMIT_SESSIONS=5

# ============================================
# إعدادات الويب هوك
# ============================================
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PATH=/webhook

# ============================================
# إعدادات الخدمات الخارجية
# ============================================
# URL Shortening Services
TINYURL_API_KEY=
BITLY_ACCESS_TOKEN=
SHORTIO_API_KEY=
CUTTLY_API_KEY=
REBRANDLY_API_KEY=

# GeoIP Database
GEOIP_DATABASE_PATH=./data/GeoLite2-City.mmdb

# Cloud Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials/google_drive.json
DROPBOX_ACCESS_TOKEN=

# ============================================
# إعدادات الإشعارات
# ============================================
NOTIFICATION_ENABLED=true
NOTIFICATION_CHANNELS=
DAILY_REPORT_TIME=09:00
WEEKLY_REPORT_DAY=monday

# ============================================
# إعدادات متقدمة
# ============================================
PROXY_URL=
USER_AGENT=Mozilla/5.0 (compatible; ZphisherBot/1.0)
REQUEST_TIMEOUT=30
CONCURRENT_REQUESTS=10