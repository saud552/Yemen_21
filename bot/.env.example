# ====================================
# 🤖 إعدادات البوت الأساسية
# ====================================
BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
BOT_NAME=ZphisherProBot
WEBHOOK_URL=

# ====================================
# 👑 إعدادات الإدارة
# ====================================
ADMIN_USER_IDS=123456789,987654321
SUPER_ADMIN_ID=123456789

# ====================================
# 🗄️ إعدادات قاعدة البيانات
# ====================================
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# ====================================
# 🔒 إعدادات الأمان
# ====================================
SECRET_KEY=auto_generated_on_startup
JWT_SECRET=auto_generated_on_startup
ENCRYPTION_KEY=auto_generated_on_startup
SESSION_LIFETIME=3600

# ====================================
# 🎣 إعدادات Zphisher
# ====================================
ZPHISHER_PATH=../zphisher.sh
ZPHISHER_SITES_PATH=../.sites/
ZPHISHER_AUTH_PATH=../auth/
ZPHISHER_SERVER_PATH=../.server/

# ====================================
# 🌐 إعدادات خدمات الأنفاق
# ====================================
CLOUDFLARED_PATH=../.server/cloudflared
LOCALXPOSE_PATH=../.server/loclx
LOCALXPOSE_TOKEN=

# ====================================
# 📊 إعدادات المراقبة والسجلات
# ====================================
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log
ENABLE_DEBUG=false
MONITORING_INTERVAL=5

# ====================================
# 📁 إعدادات تخزين الملفات
# ====================================
UPLOAD_PATH=./data/uploads/
REPORTS_PATH=./data/reports/
BACKUPS_PATH=./data/backups/
MAX_FILE_SIZE=50MB

# ====================================
# ⚡ إعدادات الحد من المعدل
# ====================================
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200
RATE_LIMIT_BURST=10

# ====================================
# 🌐 إعدادات الويب هوك
# ====================================
USE_WEBHOOK=false
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_SSL_CERT=
WEBHOOK_SSL_PRIV=

# ====================================
# 🌍 إعدادات الخدمات الخارجية
# ====================================
GEOIP_DATABASE_PATH=./data/GeoLite2-City.mmdb
URL_SHORTENER_API_KEY=

# ====================================
# 🔔 إعدادات الإشعارات
# ====================================
ENABLE_NOTIFICATIONS=true
NOTIFICATION_INTERVAL=60
ALERT_THRESHOLD_IP=5
ALERT_THRESHOLD_CREDS=3

# ====================================
# ☁️ إعدادات التخزين السحابي
# ====================================
# Amazon S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Google Drive
GOOGLE_DRIVE_CREDENTIALS_PATH=./data/google_credentials.json
GOOGLE_DRIVE_FOLDER_ID=

# Dropbox
DROPBOX_ACCESS_TOKEN=

# ====================================
# 🔗 إعدادات اختصار الروابط
# ====================================
# Bit.ly
BITLY_ACCESS_TOKEN=

# Short.io
SHORTIO_DOMAIN=
SHORTIO_API_KEY=

# Cutt.ly
CUTTLY_API_KEY=

# Rebrandly
REBRANDLY_API_KEY=
REBRANDLY_DOMAIN=

# ====================================
# 📈 إعدادات التحليل المتقدم
# ====================================
ENABLE_ADVANCED_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=30
ENABLE_DEVICE_FINGERPRINTING=true
ENABLE_GEOLOCATION_TRACKING=true

# ====================================
# 🛡️ إعدادات الأمان المتقدم
# ====================================
ENABLE_BRUTEFORCE_PROTECTION=true
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=300
ENABLE_IP_WHITELIST=false
WHITELISTED_IPS=

# ====================================
# 🔧 إعدادات متقدمة
# ====================================
ENABLE_MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=البوت تحت الصيانة، يرجى المحاولة لاحقاً
MAX_CONCURRENT_SESSIONS=5
SESSION_CLEANUP_INTERVAL=3600
TEMP_FILE_CLEANUP_INTERVAL=1800