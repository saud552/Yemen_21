# ===========================================
# BOT CONFIGURATION
# ===========================================
BOT_TOKEN=your_bot_token_here
BOT_NAME=ZphisherProBot
WEBHOOK_URL=https://your-domain.com/webhook

# ===========================================
# ADMIN CONFIGURATION
# ===========================================
ADMIN_USER_IDS=123456789,987654321
SUPER_ADMIN_ID=123456789

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
SECRET_KEY=your_super_secret_key_here_change_this
JWT_SECRET=another_secret_for_jwt_tokens
ENCRYPTION_KEY=32_char_base64_encryption_key
SESSION_LIFETIME=3600

# ===========================================
# ZPHISHER INTEGRATION
# ===========================================
ZPHISHER_PATH=../zphisher.sh
ZPHISHER_SITES_PATH=../.sites/
ZPHISHER_AUTH_PATH=../auth/
ZPHISHER_SERVER_PATH=../.server/

# ===========================================
# TUNNEL SERVICES
# ===========================================
CLOUDFLARED_PATH=../.server/cloudflared
LOCALXPOSE_PATH=../.server/loclx
LOCALXPOSE_TOKEN=your_localxpose_token

# ===========================================
# MONITORING & LOGGING
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log
ENABLE_DEBUG=false
MONITORING_INTERVAL=5

# ===========================================
# FILE STORAGE
# ===========================================
UPLOAD_PATH=./data/uploads/
REPORTS_PATH=./data/reports/
BACKUPS_PATH=./data/backups/
MAX_FILE_SIZE=50MB

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200
RATE_LIMIT_BURST=10

# ===========================================
# WEBHOOK CONFIGURATION (if using webhooks)
# ===========================================
USE_WEBHOOK=false
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_SSL_CERT=./ssl/cert.pem
WEBHOOK_SSL_PRIV=./ssl/private.key

# ===========================================
# EXTERNAL SERVICES
# ===========================================
GEOIP_DATABASE_PATH=./data/GeoLite2-City.mmdb
URL_SHORTENER_API_KEY=your_api_key_here

# ===========================================
# NOTIFICATION SETTINGS
# ===========================================
ENABLE_NOTIFICATIONS=true
NOTIFICATION_INTERVAL=60
ALERT_THRESHOLD_IP=5
ALERT_THRESHOLD_CREDS=3